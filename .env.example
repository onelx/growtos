# Supabase Configuration
# Obtené estas claves desde tu proyecto en https://supabase.com/dashboard
# Proyecto > Settings > API

# URL pública de tu proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anónima (anon/public key) - segura para usar en el cliente
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-clave-anon-key-aqui

# Clave de servicio (service_role key) - NUNCA expongas en el cliente
# Solo usarla en API routes del servidor para operaciones privilegiadas
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# Anthropic Configuration
# Obtené tu API key desde https://console.anthropic.com/
# Esta key permite llamadas a Claude AI - NUNCA expongas en el cliente
ANTHROPIC_API_KEY=sk-ant-tu-api-key-aqui

# Next.js Configuration
# URL base de tu aplicación (en desarrollo: http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment (development, staging, production)
NODE_ENV=development

# Feature Flags (opcional)
# Activar/desactivar funcionalidades en desarrollo
NEXT_PUBLIC_FEATURE_STREAMING=true
NEXT_PUBLIC_FEATURE_ADVANCED_AGENTS=false

# Rate Limiting (opcional)
# Límites de requests por usuario/IP
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Logging (opcional)
# Nivel de logs en producción (error, warn, info, debug)
LOG_LEVEL=info
